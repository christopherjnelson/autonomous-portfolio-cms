---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

// Fetch skills from Supabase
const { data: skills, error: skillsError } = await supabase
  .from('skills')
  .select('name, category');

// Fetch latest 5 achievement posts from Supabase
const { data: posts, error: postsError } = await supabase
  .from('posts')
  .select('id, title, content, date')
  .eq('type', 'achievement')
  .order('date', { ascending: false })
  .limit(5);

// Group skills by category for the grid
const skillsByCategory = (skills ?? []).reduce<Record<string, string[]>>(
  (acc, skill) => {
    (acc[skill.category] ??= []).push(skill.name);
    return acc;
  },
  {}
);

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
---

<Layout>
  <!-- About -->
  <section id="about" class="scroll-mt-20">
    <h1 class="text-3xl font-bold tracking-tight text-slate-50">About Chris</h1>
    <p class="mt-4 leading-relaxed text-slate-300">
      Chris is an IT administrator focused on cloud identity, endpoint management, and
      secure remote access. He spends his days automating provisioning, hardening
      authentication, and keeping distributed teams productive across Google Workspace
      and Microsoft 365 environments.
    </p>
  </section>

  <hr class="my-10 border-slate-800" />

  <!-- Skills -->
  <section id="skills" class="scroll-mt-20">
    <h2 class="text-2xl font-semibold tracking-tight text-slate-50">Skills</h2>
    {
      skillsError ? (
        <p class="mt-4 text-sm text-rose-400">
          Unable to load skills at this time.
        </p>
      ) : Object.keys(skillsByCategory).length === 0 ? (
        <p class="mt-4 text-sm text-slate-400">No skills listed yet.</p>
      ) : (
        <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2">
          {Object.entries(skillsByCategory).map(([category, names]) => (
            <div class="rounded-lg border border-slate-800 bg-slate-900/40 p-5">
              <h3 class="text-sm font-semibold uppercase tracking-wider text-sky-400">
                {category}
              </h3>
              <ul class="mt-3 flex flex-wrap gap-2">
                {names.map((name) => (
                  <li class="rounded-md bg-slate-800 px-3 py-1 text-sm text-slate-200">
                    {name}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      )
    }
  </section>

  <hr class="my-10 border-slate-800" />

  <!-- Feed -->
  <section id="feed" class="scroll-mt-20">
    <h2 class="text-2xl font-semibold tracking-tight text-slate-50">Feed</h2>
    {
      postsError ? (
        <p class="mt-4 text-sm text-rose-400">
          Unable to load the feed at this time.
        </p>
      ) : !posts || posts.length === 0 ? (
        <p class="mt-4 text-sm text-slate-400">No achievements yet. Check back soon.</p>
      ) : (
        <ol class="mt-6 space-y-6 border-l border-slate-800 pl-6">
          {posts.map((item) => (
            <li class="relative">
              <span class="absolute -left-[1.6rem] top-1.5 h-3 w-3 rounded-full bg-sky-400 ring-4 ring-slate-950" />
              <p class="text-xs uppercase tracking-wider text-slate-500">
                {formatDate(item.date)}
              </p>
              <h3 class="mt-1 text-lg font-semibold text-slate-100">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-300">{item.content}</p>
            </li>
          ))}
        </ol>
      )
    }
  </section>

  <hr class="my-10 border-slate-800" />

  <!-- Projects (stub) -->
  <section id="projects" class="scroll-mt-20">
    <h2 class="text-2xl font-semibold tracking-tight text-slate-50">Projects</h2>
    <p class="mt-4 text-sm text-slate-400">
      Project highlights are coming soon. Check the feed for recent work.
    </p>
  </section>
</Layout>